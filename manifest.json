{
  "manifest_version": 3,
  "name": "PositivePay for CheckKeeper",
  "version": "1.0.0",
  "description": "Select checks from CheckKeeper and export a First Citizens Bank Positive Pay CSV file.",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["https://app.checkeeper.com/*", "https://*.checkeeper.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
